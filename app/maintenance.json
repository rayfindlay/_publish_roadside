{
  "_comment": "Hand-edited fleet maintenance schedule + log. Schedule defines the recurring rules (per vehicle or `*` for all units). Log records actual events. The dashboard computes 'what's due' by finding the most recent log entry for each schedule rule and adding the interval. Edit this file directly when you log a service or change a schedule.",
  "_schedule_fields": {
    "unit": "FDT12 | FDT14 | ... | * (all) | heavy | light",
    "item": "CVIP | Oil change | Tire rotation | Brake inspection | etc.",
    "interval_type": "date | km",
    "interval_days": "(date intervals only) e.g. 365",
    "interval_km": "(km intervals only) e.g. 12000",
    "priority": "critical | routine (used only for sort order)",
    "notes": "Freeform"
  },
  "_log_fields": {
    "date": "YYYY-MM-DD when the work was done",
    "unit": "Unit ID",
    "item": "Free text; should match a schedule item for the schedule to know 'last performed'",
    "odometer_km": "Reading at time of service (optional)",
    "performer": "Norfab shop | external vendor name | etc.",
    "cost": "(optional) number, in CAD",
    "notes": "Freeform"
  },
  "_defects_resolved_fields": {
    "unit": "Unit ID the defect was reported on",
    "text_match": "Case-insensitive substring of the defect text from the SiteDocs DVI Remarks field. Matches all variants (e.g. 'Block heater' matches both 'Block heater is not working' and 'Block heater doesn't work').",
    "resolved_date": "YYYY-MM-DD when the issue was fixed. A defect re-reported on a DVI dated AFTER this will re-open in the dashboard.",
    "notes": "What was done to fix it (optional)"
  },
  "schedule": [
